    "awslint": "awslint",
    "integ-test": "integ-runner --directory ./integ-tests --parallel-regions eu-west-1 --parallel-regions eu-west-2 --parallel-regions eu-north-1 --parallel-regions eu-west-3 --update-on-failed"
