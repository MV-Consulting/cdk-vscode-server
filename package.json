    "bundle:secret-retriever/secret-retriever.lambda:watch": "projen bundle:secret-retriever/secret-retriever.lambda:watch",
    "clobber": "projen clobber",
    "compat": "projen compat",
    "compile": "projen compile",
    "default": "projen default",
