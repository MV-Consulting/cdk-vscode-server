  "author": {
    "name": "Manuel Vogel",
    "email": "info@manuel-vogel.de",
    "organization": true
  },
  "devDependencies": {
    "@aws-cdk/integ-runner": "2.190.0",
    "@aws-cdk/integ-tests-alpha": "2.190.0-alpha.0",
