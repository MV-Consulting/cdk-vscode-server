    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "aws-cdk-lib": "2.190.0",
    "awslint": "2.190.0-alpha.0",
    "commit-and-tag-version": "^12",
    "esbuild": "^0.28.0",
    "eslint": "^9",
